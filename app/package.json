{
    "name": "@openall-ai/app",
    "version": "0.2.0",
    "private": true,
    "description": "a helpful assistant",
    "license": "PolyForm Noncommercial",
    "author": "openall",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "start": "electron .",
        "build": "electron-builder",
        "build:win": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build:mac64": "electron-builder --mac --x64"
    },
    "dependencies": {
        "@openall-ai/core": "^0.2.0",
        "electron-updater": "^6.8.3"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "42.0.1",
        "electron-builder": "^26.8.1",
        "wait-on": "^9.0.5"
    },
    "build": {
        "appId": "com.openall-ai.app",
        "productName": "openall",
        "npmRebuild": false,
        "directories": {
            "output": "dist"
        },
        "publish": [
            {
                "provider": "generic",
                "url": "https://updates.openall-ai.com/openall-app"
            }
        ],
        "extraResources": [
            {
                "from": "../frontend/dist",
                "to": "frontend/dist"
            },
            {
                "from": "icons/png/256x256.png",
                "to": "icons/png/256x256.png"
            }
        ],
        "files": [
            "**/*"
        ],
        "mac": {
            "target": "dmg",
            "icon": "icons/mac/icon.icns"
        },
        "win": {
            "target": "portable",
            "icon": "icons/win/icon.ico"
        },
        "linux": {
            "target": "AppImage"
        }
    }
}